# OpenGit environment — copy to `.env` and fill in the hosts you use.
# Every value is OPTIONAL: leave a provider blank and its "Sign in" button falls
# back to pasting a personal access token. Tokens are stored in your OS keychain,
# never in this file.

# ── GitHub ── OAuth device flow ("Sign in with GitHub")
#   Create an OAuth App (enable Device Flow): https://github.com/settings/developers
OPENGIT_GH_CLIENT_ID = ''

# ── GitLab ── OAuth device flow
#   Applications → New application. Redirect URI can be anything (device flow
#   ignores it); check "Device authorization grant"; scope: api.
#   https://gitlab.com/-/user_settings/applications
OPENGIT_GITLAB_CLIENT_ID = ''

# ── Azure DevOps ── Microsoft Entra device code flow  (COMING SOON — sign-in
#    is disabled in the app for now; these are wired for when it flips on)
#   Register an app in Entra ID; enable "Allow public client flows".
#   Add API permission: Azure DevOps (user_impersonation). Paste the app's
#   Application (client) ID. TENANT is optional — defaults to "organizations"
#   (any work/school account); set a tenant GUID to lock to one org.
#   NOTE: Entra access tokens expire ~1h; you'll re-sign-in until refresh-token
#   support is added.
OPENGIT_AZURE_CLIENT_ID = ''
OPENGIT_AZURE_TENANT = ''
